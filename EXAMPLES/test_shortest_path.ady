#!/usr/bin/env py2nim
#ady2nim-args c --cc:clang --clang.exe:zigcc --clang.linkerexe:zigcc
"""Examples and tests for shortest_path.Optimizer."""

from math import log

nimport stdlib
nimport shortest_path  # provides Minimizer and Maximizer


def example1():
    # -----------------------------------------------------------------------
    # Example 1 -- simple weighted graph (Dijkstra / longest path)
    # -----------------------------------------------------------------------
    type State_T is enum s,u,x,v,y
    type Revenue_T is 0..100
    type Decision_T is State_T  # the decision is which state we will choose
    type Choice_T is (Decision_T, Revenue_T)
    # for each state, a list of choices
    var G: {State_T}[]Choice_T = {
        s: [(u, 10), (x, 5)],
        u: [(v, 1), (x, 2)],
        v: [(y, 4)],
        x: [(u, 3), (v, 9), (y, 2)],
        y: [(s, 7), (v, 6)],
    }
    class MyOptimizer(Maximizer[State_T, Decision_T, Revenue_T]):
        def get_state(self, past_decisions: []Decision_T) -> State_T:
            past_decisions[-1]
        def get_next_decisions(self, curr_state: State_T) -> []Choice_T:
            G.get(curr_state, [])

    op: MyOptimizer = MyOptimizer()
    for solution in op.longest_path(start_state=s, end_state=v, max_path_length=4):
        print("Longest path s->v:", solution)
        break

def example2():
    # -----------------------------------------------------------------------
    # Example 2 -- DP tutorial graph
    # -----------------------------------------------------------------------
    type State_T is enum a,b,c,d,e,f,g,h,i,j
    type Cost_T is 0..100
    type Revenue_T is 0..100
    type Decision_T is State_T
    type CostChoice_T is (Decision_T, Cost_T)
    type RevChoice_T is (Decision_T, Revenue_T)

    class ShortestGraph(Minimizer[State_T, Decision_T, Cost_T]):
        var G: {State_T}[]CostChoice_T = {
            a: [(b, 2), (c, 4), (d, 3)],
            b: [(e, 7), (f, 4), (g, 6)],
            c: [(e, 3), (f, 2), (g, 4)],
            d: [(e, 4), (f, 1), (g, 5)],
            e: [(h, 1), (i, 4)],
            f: [(h, 6), (i, 3)],
            g: [(h, 3), (i, 3)],
            h: [(j, 3)],
            i: [(j, 4)],
        }

        def get_state(self, past_decisions: []Decision_T) -> State_T:
            past_decisions[-1]

        def get_next_decisions(self, curr_state: State_T) -> []CostChoice_T:
            self.G.get(curr_state, [])

    class LongestGraph(Maximizer[State_T, Decision_T, Revenue_T]):
        var G: {State_T}[]RevChoice_T = {
            a: [(b, 2), (c, 4), (d, 3)],
            b: [(e, 7), (f, 4), (g, 6)],
            c: [(e, 3), (f, 2), (g, 4)],
            d: [(e, 4), (f, 1), (g, 5)],
            e: [(h, 1), (i, 4)],
            f: [(h, 6), (i, 3)],
            g: [(h, 3), (i, 3)],
            h: [(j, 3)],
            i: [(j, 4)],
        }

        def get_state(self, past_decisions: []Decision_T) -> State_T:
            past_decisions[-1]

        def get_next_decisions(self, curr_state: State_T) -> []RevChoice_T:
            self.G.get(curr_state, [])

    print('======= SHORTEST a->j =======')
    op2s: ShortestGraph = ShortestGraph()
    for solution in op2s.shortest_path(start_state=a, end_state=j):
        print(solution)
    print('======= LONGEST  a->j =======')
    op2l: LongestGraph = LongestGraph()
    for solution in op2l.longest_path(start_state=a, end_state=j):
        print(solution)
        break

def example3():
    # -----------------------------------------------------------------------
    # Example 3 -- Rod Cutting
    # You are given a rod of size n >0, it can be cut into any number of pieces k (k ≤ n).
    # Price for each piece of size i is represented as p(i) and maximum revenue from a rod of size i is r(i)
    # (could be split into multiple pieces). Find r(n) for the rod of size n.
    # -----------------------------------------------------------------------
    ROD_SIZE: Natural = 5

    type State_T is tuple:
      stage: Natural
      remaining_size: Natural
    type Revenue_T is 0..100
    type Decision_T is Positive # decision of what length we cut
    type Choice_T is (Decision_T, Revenue_T)

    class RodCutting(Maximizer[State_T, Decision_T, Revenue_T]):
      var choices: []Choice_T = [(1, 1), (2, 5), (3, 8), (4, 9), (5, 10), (6, 17), (7, 17), (8, 20), (9, 24), (10, 30)]

      def is_end_state(self, current_state: State_T) -> bool:
          let (stage, remaining_size) = current_state
          remaining_size == 0

      def get_state(self, past_decisions: []Decision_T) -> State_T:
          stage: Natural = len(past_decisions)
          used: Natural = sum(past_decisions)
          remaining_size: Natural = max(ROD_SIZE - used, 0)
          (stage, remaining_size)

      def get_next_decisions(self, current_state: State_T) -> []Choice_T:
          let (stage, remaining_size) = current_state
          [(size, rev) for size, rev in self.choices if size <= remaining_size]

    print('======= ROD CUTTING =======')
    op3: RodCutting = RodCutting()
    start_state: State_T = (0, ROD_SIZE)
    for solution in op3.longest_path(start_state):
        print(solution)
        break

def example4():
    # -----------------------------------------------------------------------
    # Example 4 -- Capital Budgeting
    # -----------------------------------------------------------------------
    const CAPITAL: Natural = 5
    type Cost_T is 0..100
    type Stage_T is enum STAGE1, STAGE2, STAGE3, END
    type State_T is tuple:
      stage : Stage_T
      budget: Cost_T
    type Decision_T is str # decision is which project for the plant
    type Revenue_T is 0..100
    type Cost_And_Revenue_T is tuple:
      cost: Cost_T
      revenue: Revenue_T
    type Choice_T is {Decision_T}Cost_And_Revenue_T
    var CHOICES: [Stage_T]Choice_T = [
        STAGE1: {'plant1-p1': (cost:0, revenue:0), 'plant1-p2': (cost:1, revenue:5), 'plant1-p3': (cost:2, revenue:6)},
        STAGE2: {'plant2-p1': (cost:0, revenue:0), 'plant2-p2': (cost:2, revenue:8), 'plant2-p3': (cost:3, revenue:9), 'plant2-p4': (cost:4, revenue:12)},
        STAGE3: {'plant3-p1': (cost:0, revenue:0), 'plant3-p2': (cost:1, revenue:4)},
    ]
    class CapitalBudgeting(Maximizer[State_T, Decision_T, Revenue_T]):
        def is_end_state(self, state: State_T) -> bool:
            state.stage == END

        def get_state(self, past_decisions: []Decision_T) -> State_T:
            stage: Stage_T = len(past_decisions)
            spent: Cost_T = 0
            for d in past_decisions:
                for stage in [STAGE1, STAGE2, STAGE3]:
                    choices: Choice_T = CHOICES[stage]
                    if d in choices:
                        spent += choices[d].cost
            (stage, Cost_T(CAPITAL) - spent)

        def get_next_decisions(self, current_state: State_T) -> [](Decision_T, Revenue_T):
            let (stage, budget) = current_state
            if stage == END:
                return []
            choices: Choice_T = CHOICES[stage]
            [(name, Revenue_T(choice.revenue)) for name, choice in choices.items() if choice.cost <= budget]

    print('======= CAPITAL BUDGETING =======')
    op4: CapitalBudgeting = CapitalBudgeting()
    for solution in op4.longest_path((stage:STAGE1, budget:Cost_T(CAPITAL))):
        print(solution)
        break

def example5():
    # -----------------------------------------------------------------------
    # Example 5 -- Knapsack
    # -----------------------------------------------------------------------
    const MAX_WEIGHT: Natural = 5
    type Revenue_T is float
    type Stage_T is enum STAGE1, STAGE2, STAGE3, END
    type State_T is tuple:
      stage: Stage_T
      remaining: Natural
    type Decision_T is tuple:
      stage: Stage_T
      quantity: Natural # the quantity of items to choose
    type Choice_T is tuple:
      weight : int # the cost
      benefit: int # the revenue
    var ITEMS: [Stage_T]Choice_T = [
      STAGE1: (weight:2, benefit:65),
      STAGE2: (weight:3, benefit:80),
      STAGE3: (weight:1, benefit:30)
    ]

    class Knapsack(Maximizer[State_T, Decision_T, Revenue_T]):
        def is_end_state(self, state: State_T) -> bool:
            state.stage == END

        def get_state(self, past_decisions: []Decision_T) -> State_T:
            stage: Stage_T = past_decisions[-1].stage'Next
            remaining: Natural = MAX_WEIGHT
            for prev_stage,qty in past_decisions:
                remaining -= qty * ITEMS[prev_stage].weight
            (stage, remaining)

        def get_next_decisions(self, current_state: State_T) -> [](Decision_T, Revenue_T):
            let (stage, remaining) = current_state
            if stage == END:
                return []
            let (weight, benefit) = ITEMS[stage]
            decisions: [](Decision_T, Revenue_T) = []
            qty: Natural = 0
            while qty * weight <= remaining:
                decisions.append(((stage:stage,quantity:qty), float(benefit * qty)))
                qty += 1
            decisions

    print('======= KNAPSACK =======')
    op5: Knapsack = Knapsack()
    for solution in op5.longest_path((stage:Stage_T'First, remaining:MAX_WEIGHT)):
        print(solution)
        break

def example6():
    # -----------------------------------------------------------------------
    # Example 6 -- Equipment Replacement
    # -----------------------------------------------------------------------
    type Decision_T is enum BUY, SELL, KEEP, TRADE
    type Cost_T is float
    const IRRELEVANT: int = -1
    const MAX_AGE: int = 3
    type Age_T is int
    type State_T is tuple: # the state is what you need to take into account when making decisions
        year: Natural
        age: int

    class EquipmentReplacement(Minimizer[State_T, Decision_T, Cost_T]):
        var maintenance_cost: {Age_T}Cost_T = {0: 60.0, 1: 80.0, 2: 120.0}
        var market_value: {Age_T}Cost_T = {0: 1000.0, 1: 800.0, 2: 600.0, 3: 500.0}

        def __init__(self, offset: float = 0.0):
            super().__init__(offset)

        def is_end_state(self, state: State_T) -> bool:
            state.year == 6

        def get_state(self, past_decisions: []Decision_T) -> State_T:
            year: Natural = len(past_decisions)
            if year == 6:
                return (6, IRRELEVANT)
            age: int = 0
            for decision in past_decisions:
                if decision == KEEP:
                    age = age + 1
                else:
                    age = 1
            (year, age)

        def get_next_decisions(self, current_state: State_T) -> [](Decision_T, Cost_T):
            let (year, age) = current_state
            case (year, age):
                when (6, _):
                    []
                when (0, _):
                    [(BUY, self.maintenance_cost[0] + self.market_value[0])]
                when (5, _):
                    [(SELL, -self.market_value[age])]
                when (_, 3):
                    [(TRADE, -self.market_value[age] + self.market_value[0] + self.maintenance_cost[0])]
                when others:
                    [
                        (KEEP, self.maintenance_cost[age]),
                        (TRADE, -self.market_value[age] + self.market_value[0] + self.maintenance_cost[0]),
                    ]

    print('======= EQUIPMENT REPLACEMENT =======')
    op6: EquipmentReplacement = EquipmentReplacement(offset=10000.0)
    start_state: State_T = (0, 0)
    for solution in op6.shortest_path(start_state):
        print(solution)

def example7():
    # -----------------------------------------------------------------------
    # Example 7 -- Romania map (A* with heuristic)
    # -----------------------------------------------------------------------
    type State_T is enum arad, bucharest, craiova, drobeta, eforie, fagaras, giurgiu, hirsova, lasi,\
     lugoj, mehadia, neamt, oradea, pitesti, rimnicu, sibiu, timisoara, urzineci, vaslui, zerind
    type Distance_T is float
    type Decision_T is State_T
    var G: {State_T}[](Decision_T, Distance_T) = {
        arad:      [(sibiu, 140.0), (timisoara, 118.0), (zerind, 75.0)],
        bucharest: [(giurgiu, 90.0), (urzineci, 85.0), (fagaras, 211.0), (pitesti, 101.0)],
        craiova:   [(rimnicu, 146.0), (pitesti, 138.0), (drobeta, 120.0)],
        drobeta:   [(craiova, 120.0), (mehadia, 75.0)],
        eforie:    [(hirsova, 86.0)],
        fagaras:   [(sibiu, 99.0), (bucharest, 211.0)],
        giurgiu:   [(bucharest, 90.0)],
        hirsova:   [(eforie, 86.0), (urzineci, 98.0)],
        lasi:      [(neamt, 87.0), (vaslui, 92.0)],
        lugoj:     [(mehadia, 70.0), (timisoara, 111.0)],
        mehadia:   [(drobeta, 75.0), (lugoj, 70.0)],
        neamt:     [(lasi, 87.0)],
        oradea:    [(zerind, 71.0), (sibiu, 151.0)],
        pitesti:   [(bucharest, 101.0), (rimnicu, 97.0), (craiova, 138.0)],
        rimnicu:   [(pitesti, 97.0), (sibiu, 80.0), (craiova, 146.0)],
        sibiu:     [(rimnicu, 80.0), (arad, 140.0), (oradea, 151.0), (fagaras, 99.0)],
        timisoara: [(lugoj, 111.0), (arad, 118.0)],
        urzineci:  [(bucharest, 85.0), (vaslui, 142.0), (hirsova, 98.0)],
        vaslui:    [(urzineci, 142.0), (lasi, 92.0)],
        zerind:    [(arad, 75.0), (oradea, 71.0)],
    }
    var HEURISTICS: {State_T}Distance_T = {
        arad: 366.0, bucharest: 0.0, craiova: 160.0, drobeta: 242.0,
        eforie: 161.0, fagaras: 176.0, giurgiu: 77.0, hirsova: 151.0,
        lasi: 226.0, lugoj: 244.0, mehadia: 241.0, neamt: 234.0,
        oradea: 380.0, pitesti: 100.0, rimnicu: 193.0, sibiu: 253.0,
        timisoara: 329.0, urzineci: 80.0, vaslui: 199.0, zerind: 374.0,
    }

    class BookMap(Minimizer[State_T, Decision_T, Distance_T]):
        def get_state(self, past_decisions: []State_T) -> State_T:
            past_decisions[-1]
        def get_next_decisions(self, current_state: State_T) -> [](Decision_T, Distance_T):
            G.get(current_state, [])
        def get_heuristic_cost(self, city: State_T) -> float:
            HEURISTICS.get(city, 0)

    op7: BookMap = BookMap()
    print("======= ROMANIA MAP: oradea -> bucharest =======")
    for solution in op7.shortest_path(start_state=oradea, end_state=bucharest):
        print(solution)


def example8():
    # -----------------------------------------------------------------------
    # Example 8 -- Least-Square Segmentation
    # Partition a series into k segments minimising the sum of squared deviations.
    # -----------------------------------------------------------------------
    type Seg_T is []int
    type State_T is tuple:
        nr_segs: Natural
        last_idx: Natural
    type Decision_T is Seg_T
    type Cost_T is float

    class LeastSquareSegmenter(Minimizer[State_T, Decision_T, Cost_T]):
        var series: []int = [10, 20, 34, 50, 60, 70, 80]

        def SSD(self, lo: Natural, hi: Natural) -> float:
            """Sum of squared deviations for series[lo:hi]."""
            sub: []int = self.series[lo:hi]
            n: Natural = hi - lo
            if n == 0:
                return 0.0
            sum_v: float = 0.0
            sum_sq: float = 0.0
            for x in sub:
                sum_v += float(x)
                sum_sq += float(x * x)
            sum_sq - (sum_v * sum_v) / float(n)

        def is_end_state(self, state: State_T) -> bool:
            state.nr_segs == 0

        def get_state(self, past_decisions: []Decision_T) -> State_T:
            nr_segs: Natural = self.start_state.nr_segs - len(past_decisions)
            last_idx: Natural = 0
            for d in past_decisions:
                last_idx += len(d)
            (nr_segs:nr_segs, last_idx:last_idx)

        def get_next_decisions(self, current_state: State_T) -> [](Decision_T, Cost_T):
            let (nr_segs, j) = current_state
            if nr_segs == 0:
                return []
            n: Natural = len(self.series)
            if nr_segs == 1:
                return [(self.series[j:], self.SSD(j, n))]
            [(self.series[j:i], self.SSD(j, i))
                    for i in range(j + 1, n - nr_segs + 1)]

    print('======= LEAST-SQUARE SEGMENTATION (2 segments) =======')
    op8: LeastSquareSegmenter = LeastSquareSegmenter()
    start_state: State_T = (nr_segs:2, last_idx:0)
    for sol in op8.shortest_path(start_state):
        print(sol)


def example9():
    # -----------------------------------------------------------------------
    # Example 9 -- Best String Alignment
    # Align two sequences with minimum edit cost (match=0, mismatch=2, gap=6).
    # -----------------------------------------------------------------------
    type State_T is tuple:
        r1: str
        r2: str
    type Decision_T is tuple:
        c1: str
        c2: str
    type Cost_T is float

    class BestAlignment(Minimizer[State_T, Decision_T, Cost_T]):
        def is_end_state(self, state: State_T) -> bool:
            state.r1 == "" and state.r2 == ""

        def get_state(self, past_decisions: []Decision_T) -> State_T:
            s1: str = self.start_state.r1
            s2: str = self.start_state.r2
            len1: Natural = 0
            len2: Natural = 0
            for d in past_decisions:
                if d.c1 != "=":
                    len1 += 1
                if d.c2 != "=":
                    len2 += 1
            (r1:s1[len1:len(s1)], r2:s2[len2:len(s2)])

        def get_next_decisions(self, current_state: State_T) -> [](Decision_T, Cost_T):
            let (r1, r2) = current_state
            case (r1,r2):
                when ("", ""):
                    return []
                when ("", _):
                    return [((c1:"=", c2:r2[0:1]), 6.0)]
                when (_, ""):
                    return [((c1:r1[0:1], c2:"="), 6.0)]
            ch1: str = r1[0:1]
            ch2: str = r2[0:1]
            cost: Cost_T = 0.0 if ch1 == ch2 else 2.0
            [
                ((c1:ch1, c2:ch2), cost),
                ((c1:"=", c2:ch2), 6.0),
                ((c1:ch1, c2:"="), 6.0),
            ]

    str1: str = "GAATTCAGTTA"
    str2: str = "GGATCGA"
    op9: BestAlignment = BestAlignment()
    print("======= BEST ALIGNMENT =======")
    for solution in op9.shortest_path((r1:str1, r2:str2)):
        print(solution)


def example10():
    # -----------------------------------------------------------------------
    # Example 10 -- Hidden Markov Model (Viterbi via shortest_path)
    # -----------------------------------------------------------------------
    from math import log
    type Hidden_State_T is enum HEALTHY, FEVER, NONE
    type Symptom_T is enum NORMAL, COLD, DIZZY
    type Prob_T is float range 0..1
    type State_T is tuple:
      stage: Natural
      hidden_state: Hidden_State_T
    class HMM(Minimizer[State_T, Hidden_State_T, Prob_T]):
        var hidden_states : []Hidden_State_T
        var start_p : [Hidden_State_T]Prob_T
        var trans_p : [Hidden_State_T][Hidden_State_T]Prob_T
        var emit_p : [Hidden_State_T][Symptom_T]Prob_T
        var obs : []Symptom_T
        def __init__(self, obs : []Symptom_T):
            super().__init__(offset=1.0)
            self.obs = obs
            self.hidden_states = [HEALTHY, FEVER]
            self.start_p  = [HEALTHY: 0.6, FEVER: 0.4]
            self.trans_p  = [
                HEALTHY: [HEALTHY: 0.7, FEVER: 0.3],
                FEVER:   [HEALTHY: 0.4, FEVER: 0.6],
            ]
            self.emit_p   = [
                HEALTHY: [NORMAL: 0.5, COLD: 0.4, DIZZY: 0.1],
                FEVER:   [NORMAL: 0.1, COLD: 0.3, DIZZY: 0.6],
            ]
        def get_state(self, past_decisions: []Hidden_State_T) -> State_T:
            if not past_decisions:
                return (stage:0, hidden_state: NONE)
            (stage:len(past_decisions), hidden_state:past_decisions[-1])
        def get_next_decisions(self, curr_state: State_T) -> [](Hidden_State_T, Prob_T):
            let (stage, curr_hidden_state) = curr_state
            if stage == len(self.obs):
                return []
            o: Symptom_T = self.obs[stage]
            if stage == 0:
                return [(h, self.start_p[h] * self.emit_p[h][o])
                        for h in self.hidden_states]
            [(h, self.trans_p[curr_hidden_state][h] * self.emit_p[h][o])
                    for h in self.hidden_states]
        def cost_operator(self, accumulated_cost: Prob_T, step_prob: Prob_T) -> Prob_T:
            accumulated_cost + log(self.offset / step_prob)
        def get_probability(self, seq: []Hidden_State_T) -> Prob_T:
            prob: Prob_T = self.start_p[seq[0]] * self.emit_p[seq[0]][self.obs[0]]
            for i in 1..seq'Last:
                prev: Hidden_State_T = seq[i-1]
                curr: Hidden_State_T = seq[i]
                o: Symptom_T = self.obs[i]
                prob *= self.trans_p[prev][curr] * self.emit_p[curr][o]
            prob
        def is_end_state(self, state: State_T) -> bool:
            state.stage == len(self.obs)

    obs = [NORMAL, COLD, DIZZY]
    hmm = HMM(obs)
    hmm.obs = obs
    print("##################################################")
    print("HIDDEN MARKOV MODEL")
    print("##################################################")
    print("Observations:", obs)
    print("Most probable hidden-state sequences (best first):")
    start_state: State_T = (stage:0, hidden_state:NONE)
    for solution in hmm.shortest_path(start_state):
        seq = solution[1]
        prob = hmm.get_probability(seq)
        print("  seq=", seq, " prob=", round(prob, 6))
    print("Predicting next state/observation:")
    best: []Hidden_State_T = []
    for solution in hmm.shortest_path(start_state):
        best = solution[1]
        break
    last_state = best[-1]
    for next_obs in [NORMAL, COLD, DIZZY]:
        for next_state in hmm.hidden_states:
            prob: float = hmm.trans_p[last_state][next_state] * hmm.emit_p[next_state][next_obs]
            print("  next_obs=", next_obs, ", next_state=", next_state, ", prob=", round(prob, 6))


if __name__=="__main__":
    example1()
    example2()
    example3()
    example4()
    example5()
    example6()
    example7()
    example8()
    example9()
    example10()
