#!/usr/bin/env py2nim
#ady2nim-args c --cc:clang --clang.exe:zigcc --clang.linkerexe:zigcc
"""Tests for state_search.StateSearcher."""

nimport state_search


# ===========================================================================
# WATER-JUG PROBLEM
# ===========================================================================
"""
You have two jugs:
  • Big jug  : capacity 5 litres
  • Small jug: capacity 3 litres

Neither jug has any measurement markings.
You have an unlimited water supply (tap) and a drain.

Legal moves
~~~~~~~~~~~
  1. Fill big    — fill the 5-litre jug to the top from the tap
  2. Fill small  — fill the 3-litre jug to the top from the tap
  3. Empty big   — pour all water in the big jug down the drain
  4. Empty small — pour all water in the small jug down the drain
  5. Pour big→small — pour from big into small until small is full or big is empty
  6. Pour small→big — pour from small into big until big is full or small is empty

Goal: have exactly 4 litres in the big jug.

State: (big, small)  where  0 ≤ big ≤ 5,  0 ≤ small ≤ 3.

Solution (BFS — fewest moves):
  (0,0) →fill big→ (5,0) →pour big→small→ (2,3) →empty small→ (2,0)
       →pour big→small→ (0,2) →fill big→ (5,2) →pour big→small→ (4,3) ✓
"""

def demo_waterjug():
    type State_T is (Natural, Natural)
    type Action_T is str

    class WaterJug(StateSearcher[State_T, Action_T]):
        var B: Natural = 5
        var S: Natural = 3
        var T: Natural = 4
        def __init__(self, cap_big: Natural = 5, cap_small: Natural = 3, target: Natural = 4):
            self.B = cap_big
            self.S = cap_small
            self.T = target

        def heuristic(self, state: State_T) -> float:
            """Distance of the big jug from the target volume."""
            let (b, _) = state
            return float(abs(b - self.T))

        def get_next_states(self, current_state: State_T) -> []Step_T[State_T, Action_T]:
            let (b, s) = current_state
            B: Natural = self.B
            S: Natural = self.S
            p_bs: Natural = min(b, S - s)
            p_sb: Natural = min(s, B - b)
            candidates: [](Action_T, State_T) = [
                ("fill big",        (B, s)),
                ("fill small",      (b, S)),
                ("empty big",       (0, s)),
                ("empty small",     (b, 0)),
                ("pour big->small", (b - p_bs, s + p_bs)),
                ("pour small->big", (b + p_sb, s - p_sb)),
            ]
            return [(from_state: current_state, action: name, next_state: ns)
                    for name, ns in candidates
                    if ns != current_state]

        def is_goal(self, state: State_T) -> bool:
            let (b, _) = state
            return b == self.T

    print("=" * 60)
    print("WATER-JUG PROBLEM  (5-litre big, 3-litre small, target 4 L)")
    print("=" * 60)

    jug: WaterJug = WaterJug(cap_big=5, cap_small=3, target=4)
    initial: State_T = (0, 0)

    print("\n[BFS — shortest solution]")
    sol_bfs: []Step_T[State_T, Action_T] = jug.search(initial)
    jug.print_solution(sol_bfs, initial)

    print("\n[DFS — depth-unlimited]")
    sol_dfs: []Step_T[State_T, Action_T] = jug.search_dfs(initial)
    jug.print_solution(sol_dfs, initial)

    print("\n[DFS — depth-limited to 5]")
    sol_dfs5: []Step_T[State_T, Action_T] = jug.search_dfs(initial, limit=5)
    jug.print_solution(sol_dfs5, initial)

    print("\n[Best-first — greedy heuristic (abs(big - target))]")
    sol_bf: []Step_T[State_T, Action_T] = jug.search_best_first(initial)
    jug.print_solution(sol_bf, initial)

    print("\n[A* — optimal with heuristic]")
    sol_astar: []Step_T[State_T, Action_T] = jug.search_astar(initial)
    jug.print_solution(sol_astar, initial)

    print("\n[All solutions — first 3 in BFS order]")
    i: Natural = 0
    for sol in jug.search_all(initial):
        print("")
        print(f"  Solution #{i + 1}  ({len(sol)} moves):")
        jug.print_solution(sol, initial)
        i += 1
        if i >= 3:
            break


# ===========================================================================
# MISSIONARIES AND CANNIBALS
# ===========================================================================

def demo_missionaries():
    # State: (missionaries_left, cannibals_left, boat_side)
    # Goal: (0, 0, right) — everyone safely on the right
    type Boat_Side_T is enum left, right
    type Missionary_Count_T is 0..3
    type Cannibal_Count_T is 0..3
    type State_T is tuple:
        number_missionaries_left : Missionary_Count_T
        number_cannibals_left : Cannibal_Count_T
        boat_location : Boat_Side_T
    type Action_T is str

    class MissionariesCannibals(StateSearcher[State_T, Action_T]):

        def is_safe(self, next_state: State_T) -> bool:
            let (M_left, C_left, _) = next_state
            M_right: Missionary_Count_T = Missionary_Count_T'Last - M_left
            C_right: Cannibal_Count_T = Cannibal_Count_T'Last - C_left
            if M_left > 0 and C_left > M_left:
                return False
            if M_right > 0 and C_right > M_right:
                return False
            return True

        def get_next_states(self, state: State_T) -> []Step_T[State_T, Action_T]:
            let (M_left, C_left, boat_location) = state
            let next_boat_location: Boat_Side_T = right if boat_location == left else left
            result: []Step_T[State_T, Action_T] = []
            for m in Missionary_Count_T'Range: # number of missionaries to put on the boat
              for c in Cannibal_Count_T'Range: # number of cannibals to put on the boat
                if m + c < 1: # boat must carry at leat 1 person
                    continue
                if m + c > 2: # boat carries at most 2 people
                    continue
                var next_state: State_T
                case boat_location:
                    when left:
                        if m > M_left:
                            continue
                        if c > C_left:
                            continue
                        next_state = (number_missionaries_left: M_left - m, 
                                      number_cannibals_left: C_left - c, 
                                      boat_location: next_boat_location)
                    when right:
                        if M_left + m > Missionary_Count_T'Last:
                            continue
                        if C_left + c > Cannibal_Count_T'Last:
                            continue
                        next_state = (number_missionaries_left: M_left + m, 
                                      number_cannibals_left: C_left + c, 
                                      boat_location: next_boat_location)
                if self.is_safe(next_state):
                    result.append((from_state: state, action: f"{m}M {c}C cross", next_state: next_state))      
            return result

        def is_goal(self, state: State_T) -> bool:
            state.number_missionaries_left == 0 and state.number_cannibals_left == 0 and state.boat_location == right

    print("\n=== MISSIONARIES AND CANNIBALS ===")
    puzzle: MissionariesCannibals = MissionariesCannibals()
    initial: State_T = (number_missionaries_left: 3, 
                        number_cannibals_left:3, 
                        boat_location: left)
    sol: []Step_T[State_T, Action_T] = puzzle.search(initial)
    puzzle.print_solution(sol, initial)


# ===========================================================================
# WOLF GOAT CABBAGE
# ===========================================================================

def demo_wolf_goat():
    type Side_T is enum left, right
    type State_T is tuple:
        farmer:  Side_T
        wolf:    Side_T
        goat:    Side_T
        cabbage: Side_T
    type Action_T is str

    class WolfGoatCabbage(StateSearcher[State_T, Action_T]):

        def is_safe(self, state: State_T) -> bool:
            let (f, w, g, c) = state
            if w == g and f != w:
                return False
            if g == c and f != g:
                return False
            return True

        def get_next_states(self, state: State_T) -> []Step_T[State_T, Action_T]:
            let (f, w, g, c) = state
            let o: Side_T = (right if f == left else left)
            candidates: [](Action_T, State_T) = [("farmer", (farmer: o, wolf: w, goat: g, cabbage: c))]
            if f == w:
                candidates.append(("take wolf",    (farmer: o, wolf: o, goat: g, cabbage: c)))
            if f == g:
                candidates.append(("take goat",    (farmer: o, wolf: w, goat: o, cabbage: c)))
            if f == c:
                candidates.append(("take cabbage", (farmer: o, wolf: w, goat: g, cabbage: o)))
            return [(from_state: state, action: name, next_state: ns)
                    for name, ns in candidates if self.is_safe(ns)]

        def is_goal(self, state: State_T) -> bool:
            let (f, w, g, c) = state
            case (f, w, g, c):
                when (right, right, right, right):
                    return True
                when others:
                    return False

    print("\n=== WOLF GOAT CABBAGE ===")
    puzzle: WolfGoatCabbage = WolfGoatCabbage()
    initial: State_T = (farmer: left, wolf: left, goat: left, cabbage: left)
    sol: []Step_T[State_T, Action_T] = puzzle.search(initial)
    puzzle.print_solution(sol, initial)


# ===========================================================================
# TOWER OF HANOI
# ===========================================================================

def demo_hanoi():
    # State: (rod_of_disk0, rod_of_disk1, rod_of_disk2)
    # disk0 = smallest, disk2 = largest; rods numbered 0, 1, 2
    # Initial: all disks on rod 0 → (0, 0, 0)
    # Goal:    all disks on rod 2 → (2, 2, 2)
    type State_T is (Natural, Natural, Natural)
    type Action_T is str

    class TowerOfHanoi(StateSearcher[State_T, Action_T]):

        def get_next_states(self, state: State_T) -> []Step_T[State_T, Action_T]:
            let (r0, r1, r2) = state
            rods: []Natural = [r0, r1, r2]
            result: []Step_T[State_T, Action_T] = []
            for disk in range(3):
                cur: Natural = rods[disk]
                # disk is on top if no smaller disk shares its rod
                on_top: bool = True
                for s in range(disk):
                    if rods[s] == cur:
                        on_top = False
                        break
                if not on_top:
                    continue
                for tgt in range(3):
                    if tgt == cur:
                        continue
                    # can place if no smaller disk is on the target rod
                    can_place: bool = True
                    for s in range(disk):
                        if rods[s] == tgt:
                            can_place = False
                            break
                    if can_place:
                        new_rods: []Natural = [rods[0], rods[1], rods[2]]
                        new_rods[disk] = tgt
                        next_state: State_T = (new_rods[0], new_rods[1], new_rods[2])
                        result.append((from_state: state, action: f"{cur}->{tgt}", next_state: next_state))
            return result

        def is_goal(self, state: State_T) -> bool:
            let (r0, r1, r2) = state
            return r0 == 2 and r1 == 2 and r2 == 2

    print("\n=== TOWER OF HANOI (3 disks) ===")
    hanoi: TowerOfHanoi = TowerOfHanoi()
    initial: State_T = (0, 0, 0)
    sol: []Step_T[State_T, Action_T] = hanoi.search(initial)
    hanoi.print_solution(sol, initial)


# ===========================================================================
# EIGHT PUZZLE
# ===========================================================================

def demo_eight_puzzle():
    # State: 9-character string, row-major; '0' = blank tile
    # e.g. "123456780" is the goal; "123406758" has blank at centre
    type State_T is str
    type Action_T is str

    GOAL_STR: State_T = "123456780"

    class EightPuzzle(StateSearcher[State_T, Action_T]):

        def heuristic(self, state: State_T) -> float:
            """Sum of Manhattan distances of each tile from its goal position."""
            total: float = 0.0
            for k in range(9):
                tile: str = state[k:k+1]
                if tile != "0":
                    goal_pos: Natural = 0
                    for j in range(9):
                        if GOAL_STR[j:j+1] == tile:
                            goal_pos = j
                            break
                    cur_row: Natural = k // 3
                    cur_col: Natural = k % 3
                    goal_row: Natural = goal_pos // 3
                    goal_col: Natural = goal_pos % 3
                    total = total + float(abs(cur_row - goal_row) + abs(cur_col - goal_col))
            return total

        def get_next_states(self, state: State_T) -> []Step_T[State_T, Action_T]:
            blank: Natural = 0
            for k in range(9):
                if state[k:k+1] == "0":
                    blank = k
                    break
            r: Natural = blank // 3
            c: Natural = blank % 3
            targets: [](int, Action_T) = []
            if r > 0:
                targets.append((blank - 3, "up"))
            if r < 2:
                targets.append((blank + 3, "down"))
            if c > 0:
                targets.append((blank - 1, "left"))
            if c < 2:
                targets.append((blank + 1, "right"))
            result: []Step_T[State_T, Action_T] = []
            for target, action in targets:
                chars: []str = []
                for k in 0..8:
                    chars.append(state[k:k+1])
                chars[blank] = state[target:target+1]
                chars[target] = "0"
                next_state: State_T = "".join(chars)
                result.append((from_state: state, action: action, next_state: next_state))
            return result

        def is_goal(self, state: State_T) -> bool:
            return state == GOAL_STR

    print("\n=== EIGHT PUZZLE ===")
    puzzle: EightPuzzle = EightPuzzle()

    print("\n[BFS — easy start (2 moves)]")
    initial: State_T = "123406758"
    sol: []Step_T[State_T, Action_T] = puzzle.search(initial)
    puzzle.print_solution(sol, initial)

    print("\n[Harder start — BFS vs best-first vs A* with Manhattan heuristic]")
    # 724506831: blank at centre, requires 20 moves optimal
    hard: State_T = "724506831"

    print("\n  BFS:")
    sol_bfs: []Step_T[State_T, Action_T] = puzzle.search(hard)
    print(f"  {len(sol_bfs)} moves")

    print("\n  Best-first (greedy Manhattan):")
    sol_bf: []Step_T[State_T, Action_T] = puzzle.search_best_first(hard)
    print(f"  {len(sol_bf)} moves")

    print("\n  A* (Manhattan):")
    sol_as: []Step_T[State_T, Action_T] = puzzle.search_astar(hard)
    print(f"  {len(sol_as)} moves (optimal)")


if __name__ == "__main__":
    demo_waterjug()
    demo_missionaries()
    demo_wolf_goat()
    demo_hanoi()
    demo_eight_puzzle()
