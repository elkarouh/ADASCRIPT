#!/usr/bin/env py2nim

def floyd(n : Positive, k : Positive) -> {}Positive:
    s : {}Positive
    for i in n-k+1..n:
        t = (1..i)'Choice
        if t in s:
            s.add(i)
        else:
            s.add(t)
    return s

let sample : {}Positive = floyd(100, 10)
print "10 distinct numbers from 1..100: ", sample