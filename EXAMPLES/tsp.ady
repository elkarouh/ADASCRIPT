let lk_msg: str = f"LK:       {n} cities  |  length: {tour_length(lk_tour):.1f}  |  time: {(t9-t8)*1000.0:.1f} ms"
print lk_msg

let t10: float = cpuTime()
let sa_tour: Tour_T = sa_tsp(lk_tour)
